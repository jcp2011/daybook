# Fully-qualified domain name at which Daybook is reachable.
# Used for the Apache ServerName and the Kerberos GssapiAcceptorName (SPN).
# Must match the /princ value used when generating the keytab with ktpass.
DAYBOOK_FQDN=daybook.company.com

# Authentication toggle.
# Set to false to disable authentication entirely (development / single-user deployments).
# Must be true in any multi-user or internet-facing environment.
AUTH_ENABLED=true

# LDAP / Active Directory settings.
# Required when AUTH_ENABLED=true.
LDAP_HOST=dc.company.com
LDAP_PORT=636
# Path inside the container to the AD root CA certificate (PEM format).
# The file must be mounted as a read-only volume (see docker-compose.yml).
# Required for LDAPS certificate verification.
LDAP_CA_CERT=/run/secrets/ad-ca.crt
LDAP_DOMAIN=company.com
LDAP_BASE_DN=DC=company,DC=com

# Service account used to perform group membership searches.
LDAP_SERVICE_DN=CN=svc-daybook,OU=ServiceAccounts,DC=company,DC=com
LDAP_SERVICE_PASSWORD=change-me

# Full DN of the AD group whose members are allowed to access Daybook.
# Nested group membership is resolved automatically.
LDAP_REQUIRED_GROUP=CN=Daybook-Users,OU=Groups,DC=company,DC=com
